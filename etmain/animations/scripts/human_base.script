DEFINES

// weapons
set weapons knives         = Knife AND Ka-Bar
set weapons pistols        = Luger AND Colt AND Silenced Luger AND Silenced Colt
set weapons akimbo_pistols = Akimbo Luger AND Silenced Akimbo Luger AND Akimbo Colt AND Silenced Akimbo Colt
// set weapons machineguns    = MP 40 AND Thompson AND Sten gun AND Flamethrower AND panzerfaust AND bazooka AND Mobile MG 42 AND Mobile Browning AND MP34
set weapons machineguns    = MP 40 AND Thompson AND Sten gun AND MP34
set weapons rifles         = K43 Rifle AND gpg40 AND m1 garand AND M7 AND FG 42 Paratroop Rifle AND Scoped K43 Rifle AND K43 Rifle Scope AND Scoped M1 Garand AND M1 Garand Scope AND FG 42 Paratroop Rifle Scope
set weapons rgrifles       = K43 Rifle AND m1 garand AND gpg40 AND m7
set weapons scopes         = K43 Rifle Scope AND M1 Garand Scope AND FG 42 Paratroop Rifle Scope
set weapons heavymgs       = Mobile MG 42 AND Mobile Browning AND Mobile MG 42 Bipod AND Mobile Browning Bipod
set weapons mortars        = Granatwerfer AND Mortar
set weapons packs          = Ammo Pack AND Satchel Charge AND medicheal
set weapons stens          = Sten gun AND MP34

set weapons one_handed_weapons = Luger AND Colt AND Silenced Luger AND Silenced Colt
set weapons two_handed_weapons = MP 40 AND Thompson AND Sten gun AND flamethrower AND panzerfaust AND bazooka AND K43 Rifle AND gpg40 AND M7 AND m1 garand AND FG 42 Paratroop Rifle AND Scoped M1 Garand AND Mobile MG 42 AND Scoped K43 Rifle AND K43 Rifle Scope AND M1 Garand Scope AND FG 42 Paratroop Rifle Scope AND Mobile Browning AND MP34

// broke off dynamite, since we never want to throw it overhand
set weapons throwables = pineapple AND grenade AND Smoke Bomb

// weapons that the player should not hold in front of themselves as if they
// could aim with them
set weapons aimless = knives AND throwables AND dynamite weapon AND smokeGrenade AND Binoculars AND Landmine AND none

set weapons all = Luger AND Colt AND Silenced Luger AND Silenced Colt AND Binoculars AND special AND Ammo Pack AND knives AND dynamite weapon AND pineapple AND grenade AND smokeGrenade AND Smoke Bomb AND Landmine AND Satchel Charge AND MP 40 AND Thompson AND Sten gun AND flamethrower AND panzerfaust AND bazooka AND Ammo Pack AND Medicheal AND gpg40 AND M7 AND m1 garand AND FG 42 Paratroop Rifle AND Scoped M1 Garand AND Satchel Charge AND Landmine AND Mobile MG 42 AND Scoped K43 Rifle AND K43 Rifle Scope AND M1 Garand Scope AND FG 42 Paratroop Rifle Scope AND Mortar AND Mounted Mortar AND Satchel Charge AND Satchel Charge Detonator AND Mobile Browning AND Granatwerfer AND Mounted Granatwerfer AND MP34
set weapons all_one_handed_weapons = Luger AND Colt AND Silenced Luger AND Silenced Colt AND Binoculars AND special AND Ammo Pack AND knives AND dynamite weapon AND pineapple AND grenade AND smokeGrenade AND Smoke Bomb AND Landmine AND Satchel Charge
set weapons all_two_handed_weapons = MP 40 AND Thompson AND Sten gun AND flamethrower AND panzerfaust AND bazooka AND Ammo Pack AND Medicheal AND gpg40 AND M7 AND m1 garand AND FG 42 Paratroop Rifle AND Scoped M1 Garand AND Satchel Charge AND Landmine AND Mobile MG 42 AND Scoped K43 Rifle AND K43 Rifle Scope AND M1 Garand Scope AND FG 42 Paratroop Rifle Scope AND Mortar AND Mounted Mortar AND Satchel Charge AND Satchel Charge Detonator AND Mobile Browning AND Granatwerfer AND Mounted Granatwerfer AND MP34

// movetypes
set movetype moving = walk AND walkcr AND walkcrbk AND walkbk AND run AND runbk AND straferight AND strafeleft
set movetype crouching = idlecr AND walkcr AND walkcrbk
set movetype backstep = walkbk AND runbk AND walkcrbk
set movetype proning = idleprone AND prone AND pronebk

//==========================================================================
// ANIMATIONS
//
//	NOTE: scripts are chosen by first-come-first-serve basis. The first match
//	      found is the one used.
//
// FORMAT:
//
// state <state description>
// {
//		<movement type>
//		{
//			[default / <condition type> [<condition value>], ...]
//			{
//				<both/legs/torso> <animation> [sound <filename>]
//				<both/legs/torso> <animation> [sound <filename>]
//				...
//			}
//		}
//	}
//
//	LEGEND:
//
//	 NOTE: 'combat' is the only state used in Multiplayer, the rest are unused SP
//	       remnants and not used.
//	<state description>: relaxed, query, alert, combat
//
//	<movement type> (see 'animMoveTypesStr'):
//		dead
//		idle
//		idlecr
//		walk
//		walkbk
//		walkcr
//		walkcrbk
//		run
//		runbk
//		straferight
//		strafeleft
//		swim
//		swimbk
//		climbup
//		climbdown
//		idleprone
//		prone
//		pronebk
//		turnright
//		turnleft
//		fallen
//		radio
//		radiocr
//		radioprone
//		midair
//
//	<condition type> (see 'animConditionsStr'):
//		weapons
//		enemy_position
//		enemy_weapon
//		underwater
//		mounted
//		movetype
//		underhand
//		leaning
//		impact_point
//		crouching
//		stunned
//		firing
//		short_reaction
//		enemy_team
//		parachute
//		charging
//		secondlife
//		health_level
//		flailing_type
//		gen_bitflag
//		aistate
//		suicide
//
//	<condition value> (bool if unspecified):
//		weapons: <see weapon pickup names>
//		enemy_weapon: <see weapon pickup names>
//		underwater: <no values>
//		mounted: MG42
//		movetype: <see movement types>
//		position: behind, infront, right, left
//		underhand: <no values>
//		leaning: right, left
//		impact_point: head, chest, gut, groin, shoulder_right, shoulder_left, knee_right, knee_left
//		health_level: 1, 2, 3

ANIMATIONS

state combat
{

	dead
	{
		default
		{
			both dead_corpse
		}
	}

	midair
	{
		weapons rifles, movetype jumpforward
		{
			legs jump_1step_2h torso stand_srifle
			// legs jump_1step_2h torso midair_1step_rifles_2h
			// torso jump_1step_midair_2h
			// both jump_1step_fire_2h
			// legs jump_1step_2h torso jump_1step_2h
		}
		weapons binoculars, gen_bitflag zooming
		{
			torso stand_binoculars
		}
		weapons satchel charge detonator
		{
			NOOP
		}
		weapons scopes
		{
			torso stand_scoped_rifle
		}
		weapons mortars
		{
			torso e_mortar_stand
		}
		weapons one_handed_weapons
		{
			torso stand_pistolB
		}
		weapons bazooka
		{
			torso stand_rifle
		}
		weapons panzerfaust
		{
			torso stand_panzer
		}
		weapons heavymgs
		{
			torso stand_mobilemg42
		}
		weapons two_handed_weapons, movetype jumpforward
		{
			torso jump_1step_midair_2h
			// both jump_1step_2h
			// NOOP
			// torso jump_1step_2h
			// torso jump_1step_fire_2h
		}
		weapons two_handed_weapons
		{
			torso stand_machinegun
			// NOOP
		}
		weapons dynamite weapon
		{
			torso jump_1step_1h
		}
		weapons akimbo_pistols
		{
			torso stand_akimbo
		}
		weapons throwables, gen_bitflag holding
		{
			torso holding_grenadeA
			torso holding_grenadeB
		}
		default
		{
			torso jump_1step_1h
		}
		// weapons knives
		// {
		// 	torso stand_knife
		// }
		// weapons pistols
		// {
		// 	torso stand_pistolB
		// }
		// default
		// {
		// 	torso jump_1step_2h
		// }
	}

	idle
	{
		// weapons Flamethrower
		// {
