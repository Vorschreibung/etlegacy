animgroup
{
	// NOTE : unused animations are commented out, but retained for
	//        reference purposes

	// Priorities by convention:
	//     99 - death
	//     20 - weapon firing/reload
	//     13 - weapon holding (grenades)
	//     10 - weapon raising
	//      8 - movement climbing
	//      5 - movement ground
	//      3 - movement air/jumping
	//      0 - idling / swimming / default

	//	<animation name>
	//	|						<first frame>
	//	|   					|   	<length>
	//	|   					|   	|   <looping>
	//	|   					|   	|   |   <fps>
	//	|   					|   	|   |   |   	<move speed>
	//	|   					|   	|   |   |   	|   <transition>
	//	|   					|   	|   |   |   	|   |   <reversed>
	//	|   					|   	|   |   |   	|   |   |   <priority>
	//	|   					|   	|   |   |   	|   |   |   |

