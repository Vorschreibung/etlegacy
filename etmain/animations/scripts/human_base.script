	{
		// - fixed movetype condition, so reenabled crouch
		// - nixing 'weapons machineguns' because we don't
		// want to just slide with any weapon
		movetype idlecr, NOT mounted MG42
		{
			legs turn_crch_L
		}
		movetype idle, NOT mounted MG42
		{
			legs turn_machinegun_R
		}
	}

	fallen
	{
		default
		{
			both wounded_idle_1
		}
	}

	radio
	{
		default
		{
			both stand_radio
		}
	}

	radiocr
	{
		default
		{
			legs alert_crchidle_1h torso stand_radio
		}
	}

	radioprone
	{
		default
		{
			legs prone_legs torso prone_poke_idle
		}
	}

}

//==========================================================================
// EVENTS
//
// format:
//
// <event description>
// {
//		[default / <condition type> [<condition value>], ...]
//		{
//			<both/legs/torso> <animation> [sound <filename>]
//			<both/legs/torso> <animation> [sound <filename>]
//			...
//		}
// }
//
// LEGEND:
//
//	<event description>:
//		fireweapon
//		fireweapon2
//		fireweaponprone
//		fireweapon2prone
//		raiseweaponprone
//		reloadprone
//		raiseweapon
//		dropweapon
//		reload
//		jump
//		jumpbk
//		climbdismount
//		death
//		revive
//		nopower
//		pain
//		do_alt_weapon_mode
//		undo_alt_weapon_mode
//		do_alt_weapon_mode_prone
//		undo_alt_weapon_mode_prone
//
//	NOTE: for gameplay anims (weapons firing, reload, etc) that show no legs movement
//		only the torso should animation from here, leave the legs doing what their
//		locomotive anims want them to do

EVENTS

fireweapon
{
	mounted MG42
	{
		both firing_mg42
	}
	weapons Mounted Mortar AND Mounted Granatwerfer
	{
		torso mortar_fire
	}
	weapons Mobile MG 42 AND Mobile Browning
